{
  "name": "@gennety/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "re-engage": "tsx src/workers/run-re-engagement.ts"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1064.0",
    "@gennety/db": "workspace:*",
    "@gennety/shared": "workspace:*",
    "@napi-rs/canvas": "^1.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "expo-server-sdk": "^4.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "grammy": "^1.35.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "openai": "^4.104.0",
    "satori": "^0.26.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
