# Telegram
BOT_TOKEN=your_telegram_bot_token
# Bot's @username without the leading @ (e.g. gennetybot). Used to build the
# https://t.me/<username> redirect URL we pass to Persona Hosted Flow so users
# land back in this bot's chat after finishing verification. Leave empty to
# disable the redirect.
BOT_USERNAME=

# Supabase (PostgreSQL + pgvector)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Telegram custom emoji IDs used for visual screening captions (optional).
# Obtain these via @stickers bot by publishing a custom emoji pack. If unset,
# screening captions fall back to the plain Unicode 👍/👎.
CUSTOM_EMOJI_LIKE_ID=
CUSTOM_EMOJI_DISLIKE_ID=

# Resend HTTP API (for university email OTP)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
SMTP_FROM=onboarding@yourdomain.com

# Admin Analytics Dashboard
ADMIN_API_KEY=your_long_random_secret
ADMIN_PORT=3100
ADMIN_DASHBOARD_ORIGIN=https://your-dashboard.vercel.app

# Public /v1/* API (Expo mobile app)
JWT_SECRET=your_64_char_random_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PUBLIC_PORT=3101
PUBLIC_CORS_ORIGIN=*

# Expo Push Service (optional — unset disables push)
EXPO_ACCESS_TOKEN=

# Supabase Storage for live-selfie uploads
SUPABASE_SELFIE_BUCKET=selfies

# Persona liveness / biometric verification (Phase 6.3)
# Dashboard: https://withpersona.com/dashboard  Docs: https://docs.withpersona.com
# Master kill switch. When false, the bot silently skips the verification step
# and activates users immediately after `finalize_onboarding`. When true, both
# the flag AND the credentials below must be set or the CTA falls through.
ENABLE_PERSONA_VERIFICATION=false
PERSONA_TEMPLATE_ID=itmpl_xxxxxxxxxxxxxxxxxxxxxxxx
PERSONA_ENVIRONMENT_ID=env_xxxxxxxxxxxxxxxxxxxxxxxx
PERSONA_API_KEY=persona_sandbox_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PERSONA_WEBHOOK_SECRET=wbhsec_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PERSONA_HOSTED_URL_BASE=https://withpersona.com/verify

# Face matching (Persona-selfie ↔ profile photos)
# `rekognition` calls AWS Rekognition CompareFaces for every profile photo
# against the Persona selfie. `disabled` short-circuits to similarity=1 so
# the rest of the verification pipeline runs unchanged in local dev / CI.
FACE_MATCH_PROVIDER=disabled
# Auto-verify threshold (0..1). AWS recommends ≥80 for security-grade apps;
# we lean stricter (0.85). Profiles in [REVIEW, VERIFY) go to manual review.
FACE_MATCH_THRESHOLD_VERIFY=0.85
FACE_MATCH_THRESHOLD_REVIEW=0.75

# AWS — used by face-match (Rekognition CompareFaces)
# IAM user must have `rekognition:CompareFaces` + `rekognition:DetectFaces`.
# Region MUST match the data-residency requirements of your user base; we
# default to eu-central-1 (Frankfurt) for GDPR alignment with EU students.
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
