# Production-like environment template.
# Do not commit real values. Local overrides belong in `.env.local`.

# --- Telegram ----------------------------------------------------------------
BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=gennetybot
WEBAPP_URL=https://dating-calendar.gennety.com
# Optional override for the post-date Feedback Mini App bundle URL. When
# empty, derived from WEBAPP_URL by appending `/feedback.html` — Vite
# emits `index.html` (calendar), `feedback.html` (feedback),
# `location.html` (venue handoff), and `onboarding.html` (Telegram
# onboarding) into the same `/var/www/dating-app` root that Caddy serves.
WEBAPP_FEEDBACK_URL=

# Optional Telegram visual affordances.
CUSTOM_EMOJI_LIKE_ID=
CUSTOM_EMOJI_DISLIKE_ID=
CUSTOM_EMOJI_MENU_ID=
CUSTOM_EMOJI_ACCEPT_ID=
CUSTOM_EMOJI_DECLINE_ID=
# Optional: animated checkmark next to a verified partner's name in the
# match-pitch caption. Empty = static `✓` glyph (still works, just no animation).
CUSTOM_EMOJI_VERIFIED_ID=
MESSAGE_EFFECT_MATCH_ID=5104841245755180586
# Optional Bot API 7.6 effect on the T+24h post-date feedback DM. Empty
# falls through to no effect — the form/voice keyboard still works.
MESSAGE_EFFECT_FEEDBACK_ID=

# --- Database / Supabase -----------------------------------------------------
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Private storage buckets.
SUPABASE_SELFIE_BUCKET=selfies
SUPABASE_PHOTO_BUCKET=profile-photos
SUPABASE_CHAT_BUCKET=chat-attachments

# --- AI / Email --------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
ONBOARDING_FACT_COLLECTOR_ENABLED=false
# Bot API 10.1 rich "thinking" shimmer for AI status/pitch streams.
# Cosmetic-only; degrades to the classic draft/edit path on any rich-API error.
RICH_THINKING_ENABLED=false
# Animated AI emoji (from https://t.me/addemoji/AIActions) that leads each
# thinking shimmer block. Empty = plain glyph, no animation. Get an id with
# getStickerSet(name="AIActions"). Only used when RICH_THINKING_ENABLED=true.
CUSTOM_EMOJI_THINKING_ID=
# Optional per-step AIActions emoji ids so a multi-beat sequence (venue search,
# date-card render) shows a distinct animated icon per step instead of the single
# shared CUSTOM_EMOJI_THINKING_ID. Each empty slot falls back to that shared id,
# then the plain glyph. Source ids with: pnpm tsx apps/bot/scripts/dev/list-ai-emojis.ts
CUSTOM_EMOJI_AI_ROUTE_ID=
CUSTOM_EMOJI_AI_VENUE_ID=
CUSTOM_EMOJI_AI_CONFIRM_ID=
CUSTOM_EMOJI_AI_CARD_ID=
CUSTOM_EMOJI_AI_SPARKLE_ID=
RESEND_API_KEY=re_your_resend_api_key
SMTP_FROM=onboarding@yourdomain.com
OTP_LOG_TO_CONSOLE=false

# --- Admin Analytics API -----------------------------------------------------
ADMIN_API_KEY=your_long_random_secret
ADMIN_PORT=3100
# Concrete dashboard origin (comma-separated for multiple). Required for
# browser access: an unset or "*" value makes the admin API deny cross-origin
# requests rather than echo a wildcard from an authenticated surface.
ADMIN_DASHBOARD_ORIGIN=https://your-dashboard.example

# --- Public /v1/* API --------------------------------------------------------
JWT_SECRET=your_64_char_random_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PUBLIC_PORT=3101
PUBLIC_CORS_ORIGIN=*

# --- Push --------------------------------------------------------------------
EXPO_ACCESS_TOKEN=

# --- Persona verification ----------------------------------------------------
ENABLE_PERSONA_VERIFICATION=false
PERSONA_TEMPLATE_ID=itmpl_xxxxxxxxxxxxxxxxxxxxxxxx
PERSONA_ENVIRONMENT_ID=env_xxxxxxxxxxxxxxxxxxxxxxxx
PERSONA_API_KEY=persona_sandbox_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PERSONA_WEBHOOK_SECRET=wbhsec_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PERSONA_HOSTED_URL_BASE=https://withpersona.com/verify

# --- Face match / Elo seed ---------------------------------------------------
# `rekognition` calls AWS CompareFaces. `disabled` short-circuits everything
# to a synthetic similarity=1 (use in CI/local dev without AWS credentials).
FACE_MATCH_PROVIDER=disabled
# Minimum similarity (0..1) for the `verified` decision. AWS recommends
# ≥0.80 for security-grade applications; 0.85 leans slightly stricter
# because dating-profile mismatches have higher harm than the friction
# of a manual review. Lower → fewer manual reviews, higher impostor risk.
FACE_MATCH_THRESHOLD_VERIFY=0.85
# Lower bound (0..1) for the manual-review band. Scores in
# [REVIEW, VERIFY) → `pending_review` (admin moderates); a score below
# REVIEW with a *detected* face → `rejected` (likely impostor photo).
FACE_MATCH_THRESHOLD_REVIEW=0.75
# Minimum number of profile photos (with a detectable face) that must
# score ≥ VERIFY for the user to be auto-verified. Photos without a
# detectable face (group shots, scenery) are excluded from the count
# rather than treated as hard fails. Default 1 — a single solid match
# is strong evidence. Raise to 2+ if ops wants corroborating angles.
FACE_MATCH_MIN_VERIFIED_PHOTOS=1
ELO_VISION_SEED_ENABLED=false
PROFILE_MEDIA_VALIDATION_ENABLED=false
PROFILE_MEDIA_VALIDATION_FAIL_OPEN=false
PROFILE_VIDEO_MAX_ANALYSIS_FRAMES=24
PROFILE_VIDEO_VALIDATION_TIMEOUT_MS=60000

# AWS Rekognition (`FACE_MATCH_PROVIDER=rekognition`). Media validation also
# requires rekognition:DetectModerationLabels.
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Venue picker ------------------------------------------------------------
PLACES_API_KEY=

# --- Cron / worker overrides -------------------------------------------------
CRON_TIMEZONE=Europe/Kyiv
MATCH_CRON_SCHEDULE=0 18 * * 4
NO_MATCH_NOTICE_CRON_SCHEDULE=15 18 * * 4
PRE_MATCH_ANNOUNCE_CRON_SCHEDULE=0 18 * * 3
EXPIRY_CRON_SCHEDULE=*/15 * * * *
PROPOSAL_COUNTDOWN_CRON_SCHEDULE=*/5 * * * *
MATCH_NUDGE_CRON_SCHEDULE=0 * * * *
RE_ENGAGEMENT_CRON_SCHEDULE=*/5 * * * *
STATUS_TIMER_CRON_SCHEDULE=* * * * *
AUTO_UNSUSPEND_CRON_SCHEDULE=0 * * * *
EMBEDDING_REFRESH_CRON_SCHEDULE=*/5 * * * *
SELFIE_RETENTION_CRON_SCHEDULE=30 3 * * *
DATE_LIFECYCLE_TICK_MS=120000
DISPATCH_DELAY_MS=2000

# Production safety: keep empty. Local-only bypass lives in `.env.local`.
DEV_OTP_BYPASS_TELEGRAM_IDS=
