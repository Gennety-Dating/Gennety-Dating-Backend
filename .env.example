# Telegram
BOT_TOKEN=your_telegram_bot_token

# Supabase (PostgreSQL + pgvector)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Telegram custom emoji IDs used for visual screening captions (optional).
# Obtain these via @stickers bot by publishing a custom emoji pack. If unset,
# screening captions fall back to the plain Unicode 👍/👎.
CUSTOM_EMOJI_LIKE_ID=
CUSTOM_EMOJI_DISLIKE_ID=

# Resend HTTP API (for university email OTP)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
SMTP_FROM=onboarding@yourdomain.com

# Admin Analytics Dashboard
ADMIN_API_KEY=your_long_random_secret
ADMIN_PORT=3100
ADMIN_DASHBOARD_ORIGIN=https://your-dashboard.vercel.app

# Public /v1/* API (Expo mobile app)
JWT_SECRET=your_64_char_random_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PUBLIC_PORT=3101
PUBLIC_CORS_ORIGIN=*

# Expo Push Service (optional — unset disables push)
EXPO_ACCESS_TOKEN=

# Supabase Storage for live-selfie uploads
SUPABASE_SELFIE_BUCKET=selfies
