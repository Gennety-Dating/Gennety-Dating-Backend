generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum UserStatus {
  onboarding
  active
  paused
  // Soft-delete: set when a user chooses "Freeze" instead of deleting their
  // account. The User/Profile/embedding/verification/coordinates are all kept;
  // the user is excluded from matching (only `active` matches) and silently
  // reactivated to `active` on their next /start. Distinct from `paused`, which
  // is a deliberate in-menu toggle with a visible banner + manual Resume.
  frozen
  suspended
  pending_investigation
  banned
}

enum Language {
  en
  ru
  uk
  de
  pl
}

/// User-selected app color theme, applied across the Mini Apps and the
/// server-rendered match / date cards. `dark` is the brand default.
enum Theme {
  light
  dark
}

enum OnboardingStep {
  consent
  language
  conversational
  completed
}

enum AiMemoryExportPreference {
  undecided
  accepted
  declined
}

enum Gender {
  male
  female
}

enum GenderPreference {
  men
  women
  both
}

enum Platform {
  telegram
  mobile
  both
}

enum WebRegistrationPurpose {
  join
  login
}

enum VerificationStatus {
  unverified
  pending
  /// Liveness passed at Persona but the face-match pipeline produced an
  /// inconclusive score (in [REVIEW, VERIFY) — see env.FACE_MATCH_THRESHOLD_*).
  /// Admin moderates these in the dashboard; users stay on `active` status
  /// (they can browse, but appear with a "review" badge to potential
  /// matches and accrue the unverified Elo penalty until cleared).
  pending_review
  verified
  rejected
}

enum MatchRadius {
  campus_only
  citywide
}

/// Priority bucket for a Profiler question. Drives both the order questions
/// are asked in (high first) and the weight their answer carries when fueling
/// icebreakers/hints (see `PROFILER_PRIORITY_WEIGHTS` in @gennety/shared).
enum ProfilerPriority {
  high
  medium
  low
}

model User {
  id               String            @id @default(uuid()) @db.Uuid
  telegramId       BigInt            @unique @map("telegram_id")
  /// Public Telegram username (without @), captured opportunistically from
  /// `ctx.from.username`. Used to build `t.me/<username>` deep links for the
  /// pre-date coordination contact-exchange variants — Telegram never issues
  /// a phone number to bots, so this is the only reliable contact handle.
  telegramUsername String?           @map("telegram_username")
  email            String?           @unique
  universityDomain String?           @map("university_domain")
  firstName        String?           @map("first_name")
  surname          String?
  age              Int?
  gender           Gender?
  preference       GenderPreference?
  major            String?
  language         Language?
  /// User-selected app color theme (Mini Apps + rendered cards). Defaults to
  /// `dark` (brand default); chosen in onboarding and changeable in Settings.
  theme            Theme             @default(dark)
  /// Set the first time the user explicitly picks a theme (onboarding theme
  /// screen or Settings). Distinguishes an explicit choice from the `dark`
  /// default, so the onboarding theme picker is shown exactly once.
  themeChosenAt    DateTime?         @map("theme_chosen_at")
  status           UserStatus        @default(onboarding)
  onboardingStep   OnboardingStep    @default(consent) @map("onboarding_step")
  /// Whether the user wants to enrich onboarding with memory exported from
  /// their existing AI assistant. `declined` skips the Magic Prompt for this
  /// onboarding run and uses a deterministic fallback profile analysis.
  aiMemoryExportPreference AiMemoryExportPreference @default(undecided) @map("ai_memory_export_preference")
  aiMemoryExportPreferenceAt DateTime? @map("ai_memory_export_preference_at")
  hasConsented     Boolean           @default(false) @map("has_consented")
  consentedAt      DateTime?         @map("consented_at")
  /// Explicit Terms of Service acceptance from the Initialization & Consent
  /// screen. Distinct from `hasConsented` (broader onboarding gate) — this
  /// is the legal ToS click and MUST be true to leave the `consent` step.
  termsAccepted    Boolean           @default(false) @map("terms_accepted")
  termsAcceptedAt  DateTime?         @map("terms_accepted_at")
  /// User opt-in to anonymized research / analytics use of their data.
  /// Defaults to false (opt-in, never opt-out) per GDPR norms.
  researchOptIn    Boolean           @default(false) @map("research_opt_in")
  emailOtp         String?           @map("email_otp")
  emailOtpExpiresAt DateTime?        @map("email_otp_expires_at")
  /// True once the user has successfully verified an OTP for `email`.
  /// Set in two places: `findOrCreateMobileUser` (mobile API after
  /// `/v1/auth/otp/verify`) and `execVerifyOtp` in the onboarding agent
  /// (Telegram bot after the `verify_otp` tool succeeds). Read by the
  /// onboarding agent to skip the email-collection step entirely when a
  /// user arrives with their email already verified (e.g. mobile-first
  /// user later opens the Telegram bot, or restarts onboarding mid-flow).
  isEmailVerified  Boolean           @default(false) @map("is_email_verified")
  /// Registration v2 (general track): phone captured via the Telegram Mini App
  /// one-tap `requestContact`. The bot receives a trusted `message.contact`
  /// (contact.user_id == from.id); client JS never sees the number. E.164.
  /// `@unique` = one account per number (curbs duplicate accounts).
  phone            String?           @unique
  /// Set when a trusted Telegram contact for THIS user is received. Phone
  /// equivalent of `isEmailVerified`; the general-track contact gate.
  phoneVerifiedAt  DateTime?         @map("phone_verified_at")
  /// Registration v2 track chosen at the sign-up fork: "student" (university
  /// email OTP) or "general" (phone). Null for users registered before the
  /// fork existed (legacy = student in practice: they all verified email).
  registrationTrack String?          @map("registration_track")
  messageHistory   Json[]            @default([]) @map("message_history")
  lastMessageAt    DateTime?         @map("last_message_at")
  /// Last time the "your match is coming tomorrow" pre-batch teaser was sent.
  /// Prevents re-sending within the same weekly cycle.
  lastPreMatchAnnounceAt DateTime?   @map("last_pre_match_announce_at")
  /// Onboarding re-engagement chain: how many touches have been delivered in
  /// the current drop-off streak (0 = chain idle, 5 = fully exhausted).
  reEngagementStep   Int             @default(0) @map("re_engagement_step")
  /// Scheduled moment of the next re-engagement touch. Null = chain inactive
  /// (either user is still engaged, onboarding complete, or chain exhausted).
  reEngagementNextAt DateTime?       @map("re_engagement_next_at")
  /// Accumulated Tier 2 strikes from verified reports.
  /// 1 → warning; 2 → 14-day suspension; ≥3 → ban.
  strikes            Int             @default(0)
  /// When a `suspended` status should auto-revert to `active`.
  /// Consumed by the match-engine tick; null for all non-suspended users.
  suspendedUntil     DateTime?       @map("suspended_until")
  /// Telegram `message_id` of the pinned "next match in …" status banner.
  /// Null = no banner pinned (either pre-finalize, or user unpinned / deleted).
  /// Cleared by the status-timer worker on 400/403 edit failures.
  statusMessageId    Int?            @map("status_message_id")
  /// Identity origin. Mobile-first users are created with a synthetic negative
  /// `telegramId` (Telegram never issues negative IDs) — Telegram-targeting
  /// workers MUST filter `telegramId: { gt: 0 }` or `platform: { in: [telegram, both] }`.
  platform            Platform       @default(telegram)
  /// Expo / APNs / FCM push token registered by the mobile app.
  pushToken           String?        @map("push_token")
  pushPlatform        String?        @map("push_platform")
  /// Liveness verification state (Phase 6.3 of the product spec).
  /// Backed by Persona hosted flow (withpersona.com) for both mobile and bot.
  verificationStatus  VerificationStatus @default(unverified) @map("verification_status")
  /// Legacy mobile-side selfie path from the pre-Persona era. No new code
  /// writes here; kept as nullable for historical rows. Safe to drop later.
  selfiePath          String?        @map("selfie_path")
  /// Persona `inquiry` id captured from webhook events. Idempotent marker so
  /// retries don't double-process the same inquiry; also used to cross-link
  /// the Persona dashboard audit trail.
  personaInquiryId    String?        @unique @map("persona_inquiry_id")
  /// Timestamp the inquiry flipped this user to `verified`. Re-verifications
  /// overwrite.
  verifiedAt          DateTime?      @map("verified_at")
  /// Timestamp the user explicitly tapped "Skip" on the verification CTA at
  /// the end of onboarding. Mutually exclusive with `verifiedAt` — a later
  /// successful Persona run clears this. Drives the unverified-Elo penalty
  /// applied at decision time and surfaces in the admin dashboard.
  verificationSkippedAt DateTime?    @map("verification_skipped_at")
  /// Supabase Storage path (in env.SUPABASE_SELFIE_BUCKET) of the selfie
  /// Persona captured during liveness. Set by the verification pipeline
  /// after a successful `inquiry.approved` event; used as the ground-truth
  /// reference for face-matching against profile photos (initial pass and
  /// any future photo edits). Auto-deleted by the retention worker 90 days
  /// after `verifiedAt` — the storage path is null thereafter even though
  /// the user remains `verified`. Re-verifications (or photo edits past the
  /// 90-day window) re-fetch ephemerally from Persona via `personaInquiryId`
  /// and fail closed if no authoritative reference is available.
  verifiedSelfiePath  String?        @map("verified_selfie_path")
  /// Minimum face-match similarity (0..1) across all profile photos, taken
  /// against `verifiedSelfiePath`. Below `env.FACE_MATCH_THRESHOLD_VERIFY`
  /// → `pending_review` or `rejected`. Null on legacy verified users (the
  /// migration explicitly opts them out of retroactive face-matching — see
  /// admin dashboard for the manual re-trigger).
  faceMatchScore      Float?         @map("face_match_score")
  /// Timestamp of the most recent face-match pass. Distinct from
  /// `verifiedAt` (which only flips on the first successful liveness pass)
  /// — `faceMatchedAt` updates on every photo upload past the initial run.
  faceMatchedAt       DateTime?      @map("face_matched_at")
  /// First-touch attribution captured once on user creation. Format is
  /// free-form (`tg:start_param`, `mobile:utm=ig_story`, `referral:USER_ID`)
  /// — the analytics layer parses prefixes. Never overwritten after the
  /// initial write so growth attribution stays stable across re-onboarding.
  referralSource      String?        @map("referral_source")
  /// Materialized ticket wallet balance (Date Ticket monetization, gated by
  /// `TICKET_FEATURE_ENABLED`). A ticket is spent at the §3.5b date gate; it
  /// is topped up by bundle purchases (the store Mini App) and one-time
  /// onboarding bonuses (4+ profile photos, adding a profile video). This is
  /// the materialized counter — every change is written atomically alongside a
  /// `TicketLedger` audit row in the same transaction, so the ledger is the
  /// append-only source of truth and this column is its running sum.
  ticketBalance       Int            @default(0) @map("ticket_balance")
  /// One-time "famine" single-ticket discount (Date Ticket monetization, gated
  /// by `TICKET_FEATURE_ENABLED`). Granted when the user is eligible-but-unpaired
  /// for a 2nd consecutive weekly batch (no-match tier >= 2). It discounts a
  /// SINGLE ticket purchase — the date gate's `self` scope and the store's
  /// "1 ticket" bundle — and is consumed on the first such purchase. See
  /// PRODUCT_SPEC.md §3.5b and `services/ticket-discount.ts`.
  /// Active ⇔ `ticketDiscountPct > 0 AND ticketDiscountConsumedAt IS NULL AND
  /// ticketDiscountExpiresAt > now`. `0`/nulls = no active discount.
  ticketDiscountPct        Int       @default(0) @map("ticket_discount_pct")
  ticketDiscountGrantedAt  DateTime? @map("ticket_discount_granted_at")
  ticketDiscountExpiresAt  DateTime? @map("ticket_discount_expires_at")
  ticketDiscountConsumedAt DateTime? @map("ticket_discount_consumed_at")
  /// Founder-notify (gated by `FOUNDER_NOTIFY_ENABLED`): stamped the first time
  /// this user becomes `active` and the "new registration" profile card is sent
  /// to the founder's personal Telegram. Idempotency marker — the notifier
  /// updates it with `where: { founderNotifiedAt: null }`, so re-activation
  /// (verified-after-skip, unfreeze on `/start`) never re-sends. Null = never
  /// notified.
  founderNotifiedAt DateTime?        @map("founder_notified_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  profile Profile?
  onboardingProgress OnboardingProgress?
  onboardingStepEvents OnboardingStepEvent[]
  sessions UserSession[]
  profilerAnswers ProfilerAnswer[]
  ticketLedger TicketLedger[]
  mediaValidationRejections MediaValidationRejection[]

  matchesAsA Match[] @relation("MatchUserA")
  matchesAsB Match[] @relation("MatchUserB")
  matchEventsAuthored MatchEvent[] @relation("MatchEventActor")
  matchEventsTargeted MatchEvent[] @relation("MatchEventTarget")

  reportsFiled    Report[] @relation("ReportReporter")
  reportsAgainst  Report[] @relation("ReportReported")

  messages Message[]

  noMatchNotices NoMatchNotice[]

  @@index([status, reEngagementNextAt])
  @@index([status, suspendedUntil])
  @@map("users")
}

/// Append-only audit log of every ticket-wallet movement (Date Ticket
/// monetization, gated by `TICKET_FEATURE_ENABLED`). The running sum of
/// `delta` equals `User.ticketBalance`, which is materialized for fast reads;
/// both are written in the same transaction by `services/ticket-wallet.ts`.
///
/// `reason` (string, validated in app code — not a Prisma enum):
///   photo_bonus    — +1 one-time bonus for reaching 4+ profile photos
///   video_bonus    — +1 one-time bonus for adding a profile video
///   verification_bonus — +1 one-time bonus for successful identity verification
///   store_purchase — +N from a bundle purchase in the store Mini App
///   spend_match    — -1 (or -2) consumed at the §3.5b date gate
///   refund         — +N wallet reversal (e.g. an expired/refunded match ticket)
///   gate_payment / gate_processing / gate_settled — atomic Stars settlement
///   gate_surplus_pending — durable pending wallet credit for partial overpay
///   gate_refund_pending / gate_refunded — durable Stars refund state
model TicketLedger {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  /// Signed change applied to the balance (+ grants/purchases, - spends).
  delta       Int
  reason      String
  /// Set for `spend_match`/`refund` rows so a movement can be traced to the
  /// match it paid for. Free-form (no FK) so deleting a match never breaks the
  /// audit trail.
  matchId     String?  @map("match_id") @db.Uuid
  /// Money attached to a purchase row (cents) — null for free bonuses/spends.
  amountCents Int?     @map("amount_cents")
  /// Bundle size for `store_purchase` rows (1 / 3 / 6).
  bundleSize  Int?     @map("bundle_size")
  /// Unique provider charge id (Telegram Stars `telegram_payment_charge_id`)
  /// set on paid store purchases and date-gate Stars payments. Its unique
  /// constraint makes Telegram redelivery exactly-once and preserves the charge
  /// id required for later expiry refunds. Synthetic ids also dedupe wallet
  /// reversals and surplus credits.
  externalPaymentId String? @unique @map("external_payment_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ticket_ledger")
}

model OnboardingProgress {
  userId           String    @id @map("user_id") @db.Uuid
  completedFields  String[]  @default([]) @map("completed_fields")
  skippedFields    String[]  @default([]) @map("skipped_fields")
  askedFields      String[]  @default([]) @map("asked_fields")
  currentQuestion  String?   @map("current_question")
  collectorVersion Int       @default(1) @map("collector_version")
  revision         Int       @default(0)
  backfilledAt     DateTime? @map("backfilled_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
}

/// Append-only onboarding funnel telemetry: one row per step transition.
/// `kind = asked` when a step is first surfaced to the user; `answered` /
/// `skipped` when they resolve it (advancing to the next step). `dwellMs` on
/// an `answered`/`skipped` row is the wall-clock gap since that step's matching
/// `asked` row — i.e. how long the user hesitated on that step. Drop-off is
/// derived, not stored: a still-`onboarding` user whose latest `asked` step has
/// no matching `answered`/`skipped` is stuck there. Feeds the
/// `/admin/analytics/onboarding-funnel` endpoint (drop-off %, dwell median/p90,
/// abandonment hotspots). Written from the onboarding collector's existing
/// persistence transaction (`services/onboarding-analytics.ts`); never mines
/// personal answers — only the step key, its outcome, and timing.
model OnboardingStepEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  /// Step key: an `ONBOARDING_QUESTIONS` value (first_name_age, gender, …,
  /// photos), the trailing `verification` CTA, or a Mini-App macro step
  /// (consent/language/city/theme/ai_memory).
  step      String
  /// `asked` | `answered` | `skipped`.
  kind      String
  /// ms hesitated on this step (now − matching `asked`); null on `asked` rows
  /// and when no matching `asked` was found.
  dwellMs   Int?     @map("dwell_ms")
  language  String?
  platform  String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([step, kind, createdAt])
  @@map("onboarding_step_events")
}

model Profile {
  id                   String                    @id @default(uuid()) @db.Uuid
  userId               String                    @unique @map("user_id") @db.Uuid
  ethnicity            String?
  height               Int?
  hobbies              String[]                  @default([])
  partnerPreferences   String?                   @map("partner_preferences")
  psychologicalSummary String?                   @map("psychological_summary")
  negativeConstraints  String?                   @map("negative_constraints")
  ageRangeMin          Int?                      @map("age_range_min")
  ageRangeMax          Int?                      @map("age_range_max")
  embedding            Unsupported("vector(1536)")?
  /// M-2: dirty flag set by any code path that mutates a field which feeds
  /// the embedding (psychologicalSummary, partnerPreferences,
  /// negativeConstraints, hobbies). The `embedding-refresh` background
  /// worker picks dirty rows up every few minutes, recomputes via OpenAI,
  /// and clears the flag. Pre-M-2 the embedding silently went stale every
  /// time a user edited their profile, degrading match quality forever.
  embeddingDirty       Boolean   @default(false) @map("embedding_dirty")
  embeddingDirtyAt     DateTime? @map("embedding_dirty_at")
  /// Universal Elo rating in [0..1000]. Seeded by the AI vision pass on the
  /// primary photo when Persona flips the user to `verified`
  /// (see `apps/bot/src/services/elo/seed-from-vision.ts`), then updated on
  /// each Thursday accept/decline event (see `apps/bot/src/utils/elo-calculator.ts`).
  /// Drives the `V_league` multiplier in match scoring — large rating gaps
  /// decay the candidate's score so users mostly see opponents in their league.
  eloScore             Int               @default(500) @map("elo_score")
  /// Lifetime count of resolved match events used to drive the dynamic K-factor:
  /// K=20 while < 10 (fast calibration), K=10 thereafter. Half the textbook
  /// chess defaults so the photo-derived cold-start seed dominates and
  /// behavioral updates remain a secondary refinement.
  eloMatchesPlayed     Int               @default(0) @map("elo_matches_played")
  /// Idempotency marker: timestamp the cold-start AI vision pass seeded
  /// `eloScore`. Persona webhook retries skip the OpenAI call when set.
  /// Null on legacy rows and on users who haven't yet completed verification.
  eloSeededAt          DateTime?         @map("elo_seeded_at")
  /// Raw vision-pass output stored alongside `eloSeededAt`: the SCUT-FBP5500-
  /// style sub-scores (symmetry, eye distance, face shape, feature regularity),
  /// the overall 0..100 score, the model name, and the mapped Elo. Lets ops
  /// answer "why did this user start at 720?" with a single SELECT instead of
  /// re-running the OpenAI call. Null for users seeded before the feature
  /// shipped or when the seeding flag was disabled.
  eloSeedDetails       Json?             @map("elo_seed_details")
  photos               String[]                  @default([])
  /// Structured profile media displayed in Telegram cards. This is
  /// deliberately additive: `photos[]` remains the ordered static-photo
  /// source for verification and fallback, while each `profile_media[]`
  /// item can carry richer Telegram media metadata, e.g.
  /// `{ type: "live_photo", photo: "<static file_id>", livePhoto: "<video file_id>" }`.
  /// Empty on legacy rows; callers normalize it from `photos[]`.
  profileMedia         Json[]                    @default([]) @map("profile_media")
  /// Provider-neutral upload-time identity anchor for onboarding/profile media.
  /// V1 stores non-secret anchor metadata for the first accepted photo while
  /// actual face comparison continues to use transient image bytes.
  referenceFaceEmbedding Json?                   @map("reference_face_embedding")
  /// Perceptual hashes for accepted static photos, in upload order. Used for
  /// cheap duplicate rejection before moderation/face provider calls.
  uploadedPhotoHashes  String[]                  @default([]) @map("uploaded_photo_hashes")
  /// Static photos that passed per-photo safety/face/duplicate validation but
  /// have not yet formed a 2+ photo identity-consensus cluster. These are not
  /// rendered, counted toward MIN_PHOTOS, or used by matching/verification.
  pendingPhotoCandidates Json[]                   @default([]) @map("pending_photo_candidates")
  /// Count of static photos accepted by upload-time validation. Videos are
  /// display-only and are not counted toward this value.
  acceptedPhotoCount   Int                       @default(0) @map("accepted_photo_count")
  /// Per-photo face-match similarity (0..1) against User.verifiedSelfiePath,
  /// ordered 1:1 with `photos[]`. Empty for unverified users and for
  /// pre-feature legacy rows. Populated by the verification pipeline on
  /// initial verify and by the photo-upload gate on every subsequent edit.
  /// Stored alongside `photos` (rather than computed on the fly) so the
  /// admin dashboard can spot the *specific* offending photo when a user
  /// lands in `pending_review`, instead of recomputing N Rekognition calls.
  photoFaceScores      Float[]                   @default([]) @map("photo_face_scores")
  /// Mobile-side match radius preference. Telegram users inherit the default.
  matchRadius          MatchRadius               @default(campus_only) @map("match_radius")
  /// Persistent "home base" coordinates used by the Meet-Halfway matching
  /// algorithm to compute great-circle distance / midpoints between candidates.
  /// Distinct from `Match.vibeLat{A,B}` which are per-match commute pins set
  /// during venue negotiation. Nullable: a user may not have shared location
  /// yet (legacy rows, declined OS prompt). Updated via `POST /v1/me/location`.
  latitude             Float?                    @map("latitude")
  longitude            Float?                    @map("longitude")
  /// Freshness marker for the home coordinates. The matching engine can
  /// fall back to `matchRadius`-only scoring when this is stale or null.
  locationUpdatedAt    DateTime?                 @map("location_updated_at")
  /// Canonical dating city selected during onboarding. This is the hard
  /// local matching boundary: users can match across university domains only
  /// when they share the same `homeCityKey`.
  homeCity             String?                   @map("home_city")
  homeCountryCode      String?                   @map("home_country_code")
  homeCityKey          String?                   @map("home_city_key")
  homePlaceId          String?                   @map("home_place_id")
  /// Last time this profile was included in a `Match` row. Used by the
  /// match-engine tick to avoid re-pairing the same user within a cooldown.
  lastMatchedAt        DateTime?                 @map("last_matched_at")
  /// Consecutive weekly batches where this profile was eligible but left
  /// unpaired, plus compensating boosts when the user accepted a proposal
  /// but the peer declined. Reset to 0 on a successful pairing. Read by the
  /// scoring function as a capped priority bonus (see `starvationBonus`).
  missedWeeks          Int                       @default(0) @map("missed_weeks")
  /// Canonical standby/starvation counter used by the premium "Standby Mode"
  /// UX. Incremented when a user is eligible for the weekly batch but left
  /// unmatched, or accepts a proposal but the peer declines; reset to 0 on a
  /// successful pairing.
  standbyCount         Int                       @default(0) @map("standby_count")
  /// Timestamp of the most recent batch/unresolved accepted-side outcome that
  /// boosted this profile. Drives the "priority boosted" UX ping.
  lastMissedAt         DateTime?                 @map("last_missed_at")
  /// Number of times this profile silently let a match proposal expire
  /// (24h passed without Accept/Decline). Counted post-expiry by
  /// `expireStaleMatches`. Forgive-once gate: first offense = warning only,
  /// from the second onwards Elo is decremented as if the user had declined.
  silentIgnoreCount    Int                       @default(0) @map("silent_ignore_count")
  /// IANA timezone (e.g. "Europe/Kyiv") resolved from the user's dating city.
  /// Drives the Profiler's morning/evening batch windows in the user's local
  /// wall-clock time. Null → the scheduler falls back to Europe/Kyiv. Derived
  /// at city-selection time via `cityKeyToTimeZone` in @gennety/shared.
  timeZone             String?                   @map("time_zone")
  /// Profiler (PRODUCT_SPEC §Phase 1b) scheduler state. The Profiler harvests
  /// gender-specific Q&A in timed batches after onboarding to fuel icebreakers
  /// and date-planning hints — it is NOT used by the matching algorithm.
  ///   - `profilerStartedAt`: seed marker; null = the post-onboarding entry
  ///     timer hasn't been armed yet (lazily seeded by the worker for legacy
  ///     rows, precisely at finalize for new completions).
  ///   - `profilerNextAt`: when the next batch's first question may be sent.
  ///     Null while a batch is in flight (driven by replies) or when every
  ///     question is answered.
  ///   - `profilerActiveQuestionId`: the question currently awaiting a reply;
  ///     null = not awaiting. Used by the answer/skip handler.
  ///   - `profilerBatchRemaining`: questions left to send in the current batch
  ///     before pausing to the next window.
  profilerStartedAt        DateTime?             @map("profiler_started_at")
  profilerNextAt           DateTime?             @map("profiler_next_at")
  profilerActiveQuestionId String?               @map("profiler_active_question_id")
  profilerBatchRemaining   Int                   @default(0) @map("profiler_batch_remaining")
  /// One-time onboarding ticket-bonus idempotency markers (gated by
  /// `TICKET_FEATURE_ENABLED`). Set the first time the profile reaches 4+
  /// face-validated photos (`photoBonusTicketAt`) or gains a profile video
  /// (`videoBonusTicketAt`). The grant is never re-issued, even if the user
  /// later edits photos/video. See `services/ticket-wallet.ts`.
  photoBonusTicketAt   DateTime?                 @map("photo_bonus_ticket_at")
  videoBonusTicketAt   DateTime?                 @map("video_bonus_ticket_at")
  /// Vibe signal (PRODUCT_SPEC §1.3 / §3.2). Collected as two short free-text
  /// onboarding answers right before the Magic Prompt step, asked of EVERY user
  /// regardless of AI-memory export choice. The raw text feeds icebreakers and
  /// is folded into `psychologicalSummary` so the embedding (V_explicit) carries
  /// real psychological signal even when the Magic Prompt is declined.
  ///   - `fridayVibeText`: "describe your ideal Friday night, honestly".
  ///   - `vibeFocusText`: "what matters more — the process, or who's with you?".
  fridayVibeText       String?                   @map("friday_vibe_text")
  vibeFocusText        String?                   @map("vibe_focus_text")
  /// Structured axes extracted from the two vibe answers at finalize, scored by
  /// V_research (quadrant proximity). `[-1,+1]` continuous.
  ///   - `energyAxis`: internal (-1) ↔ external (+1) energy — the "tempo" axis.
  ///   - `orientationAxis`: experience (-1) ↔ connection (+1).
  energyAxis           Float?                    @map("energy_axis")
  orientationAxis      Float?                    @map("orientation_axis")
  /// Social role inferred from the vibe answers: initiator | participant |
  /// observer (whitelist-validated in app code, NOT a Prisma enum — mirrors
  /// `CuratedVenue.category`). STORED but not yet scored: role-complementarity
  /// matching (Phase 2) is deferred until there is accept/decline data to
  /// validate it against. See PRODUCT_SPEC §3.2.
  socialRole           String?                   @map("social_role")
  /// Concrete "anchor" interests pulled from the vibe answers (food, music,
  /// nature, ideas, humor, …). Icebreaker fuel + future shared-anchor scoring;
  /// the embedding stays authoritative for anchor similarity in v1.
  anchorTags           String[]                  @default([]) @map("anchor_tags")
  /// Idempotency/audit marker: when the vibe-axis extraction last ran. Guards
  /// the accepted-path summary append so finalize retries don't double-append.
  vibeExtractedAt      DateTime?                 @map("vibe_extracted_at")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([profilerNextAt])
  @@map("profiles")
}

/// One row per (user, Profiler question). The Profiler (PRODUCT_SPEC §Phase 1b)
/// asks gender-specific questions in timed batches to fuel icebreakers and
/// date-planning hints. Deliberately NOT an input to the matching algorithm.
///
/// A question is answered at most once per user lifetime (`@@unique`); a later
/// drop cycle re-asks only still-unanswered questions. `skipped`/`skipReturned`
/// implement the "a skipped question comes back once per cycle, then drops"
/// rule; `cycleId` records the drop cycle the row was last touched in.
model ProfilerAnswer {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  /// Stable question identifier from the shared question bank (e.g. "f_date_spots").
  questionId   String           @map("question_id")
  priority     ProfilerPriority
  /// Free-text answer. Null while the question is only skipped (not answered).
  answerText   String?          @map("answer_text")
  answeredAt   DateTime?        @map("answered_at")
  /// True when the user tapped "Skip" instead of answering.
  skipped      Boolean          @default(false)
  /// True once a skipped question has been re-offered the one allowed time in
  /// its cycle, so it isn't surfaced a third time until the next drop cycle.
  skipReturned Boolean          @default(false) @map("skip_returned")
  /// Drop cycle this row was last asked/answered in (ISO date of the drop).
  cycleId      String           @map("cycle_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@map("profiler_answers")
}

enum MatchStatus {
  proposed
  negotiating
  negotiating_venue
  scheduled
  cancelled
  completed
  expired
}

enum MatchEventActionType {
  PROPOSAL_SHOWN
  ACCEPTED
  DECLINED
  DATE_COMPLETED
  CHEMISTRY_POSITIVE
  CHEMISTRY_NEGATIVE
  /// 24h TTL elapsed without the user replying — this row's `actorId` is
  /// the silent side. Emitted once per offending side per match.
  EXPIRED_SILENT
  /// Counterpart event for the side that DID respond on a match where the
  /// peer went silent past TTL. `actorId` is the responder, `targetId` the
  /// silent peer. Used for the "your match ignored you" notification audit.
  EXPIRED_PEER_IGNORED
}

model Match {
  id           String      @id @default(uuid()) @db.Uuid
  userAId      String      @map("user_a_id") @db.Uuid
  userBId      String      @map("user_b_id") @db.Uuid
  status       MatchStatus @default(proposed)
  pitchForA    String?     @map("pitch_for_a")
  pitchForB    String?     @map("pitch_for_b")

  /// AI Synergy Score — pair-level compatibility metric shown on the match
  /// reveal and upcoming-date screens. Always clamped server-side to the
  /// motivating 70..99 range; the LLM is *asked* for that range, but a
  /// clamp + fallback in `pitch-generator.ts` is the source of truth.
  /// `synergyReason` is a 1–2 sentence positive justification framed as
  /// "complementary" (70–79) or "highly aligned" (80–99). The reason is
  /// generated in side-A's language to keep the column singular per spec.
  synergyScore  Int?    @map("synergy_score")
  synergyReason String? @map("synergy_reason")

  /// Per-user Accept/Decline state. NULL = pending, true = accepted,
  /// false = declined. Both must be true for the match to enter `negotiating`.
  acceptedByA  Boolean?    @map("accepted_by_a")
  acceptedByB  Boolean?    @map("accepted_by_b")

  /// Free-form reason captured from a user who declined the match. AI parses
  /// this text and appends distilled constraints to `Profile.negativeConstraints`.
  rejectionReasonA String? @map("rejection_reason_a")
  rejectionReasonB String? @map("rejection_reason_b")

  /// DEPRECATED. Pre-2026-05 the scheduler had three iterations (two rounds
  /// of bot inline-keyboard "single slot" picks, then a Mini App fallback).
  /// Current flow goes straight to the Mini App after both users accept;
  /// this column is kept for any in-flight rows mid-deploy and will be
  /// dropped in a follow-up cleanup migration.
  schedulingIteration Int        @default(0) @map("scheduling_iteration")
  /// Server-side allowlist of valid calendar slots (the visible grid in the
  /// Mini App). Generated when the match enters `negotiating`. The public
  /// `POST /v1/calendar/pick` endpoint validates every submitted slot
  /// against this list to prevent clients from POSTing arbitrary timestamps.
  proposedTimes       DateTime[] @map("proposed_times")
  /// Per-user availability set selected in the Mini App calendar. A non-empty
  /// intersection between `availableTimesA` and `availableTimesB` agrees the
  /// date — the *earliest* common slot wins so peer-confirmation taps land
  /// on the slot the partner actually marked.
  availableTimesA     DateTime[] @default([]) @map("available_times_a")
  availableTimesB     DateTime[] @default([]) @map("available_times_b")
  /// DEPRECATED. Single-slot picks from the legacy iter-1/2 inline keyboards.
  /// New flow uses `availableTimesA/B`; these stay for any in-flight matches
  /// at deploy time and will be dropped in a follow-up cleanup migration.
  pickedTimeA         DateTime?  @map("picked_time_a")
  pickedTimeB         DateTime?  @map("picked_time_b")

  agreedTime   DateTime?   @map("agreed_time")
  venueName    String?     @map("venue_name")
  venueAddress String?     @map("venue_address")

  /// Phase 3.4: Concierge venue negotiation (after agreedTime is locked).
  /// Each user submits a free-text "vibe" (cafe/restaurant/park/etc.) and a
  /// Telegram Location pin of where they're commuting from. The bot computes
  /// the great-circle midpoint, safety-parses both vibes against a strict
  /// public-place whitelist, and queries Google Places centered on the
  /// midpoint. All fields nullable — populated incrementally as each user
  /// responds; once all four of (vibeText*, vibeLat*) pairs are present the
  /// match finalizes to `scheduled`.
  vibeTextA        String? @map("vibe_text_a")
  vibeTextB        String? @map("vibe_text_b")
  vibeLatA         Float?  @map("vibe_lat_a")
  vibeLngA         Float?  @map("vibe_lng_a")
  /// Human-readable address each user picked in the Location Mini App
  /// (e.g. "Lukyanivska Metro Station, Kyiv"). Used for display in the
  /// concierge confirmation message — not for the matching algorithm
  /// (lat/lng above is the source of truth for midpoint computation).
  /// Null when the user shared a raw location pin via Telegram's attach
  /// menu instead of using the Mini App.
  vibeAddressA     String? @map("vibe_address_a")
  vibeAddressB     String? @map("vibe_address_b")
  vibeLatB         Float?  @map("vibe_lat_b")
  vibeLngB         Float?  @map("vibe_lng_b")
  /// Whitelisted Places category after safety override (cafe | restaurant |
  /// coffee_shop | park | museum | lounge). Audit trail for overrides.
  parsedCategoryA  String? @map("parsed_category_a")
  parsedCategoryB  String? @map("parsed_category_b")
  /// Resolved midpoint used for the Places query — kept for audit / retries.
  venueLat         Float?  @map("venue_lat")
  venueLng         Float?  @map("venue_lng")
  /// Google Maps deep-link to the picked place (`googleMapsUri` from the
  /// Places API (New) response). Surfaced in the final scheduled DM so
  /// users can verify the venue exists and pre-check address / hours.
  /// Null on the legacy domain-based venue path (no Maps URI available
  /// there) and on local-stub fallbacks.
  venueGoogleMapsUri String? @map("venue_google_maps_uri")
  /// Date-card venue imagery (feature-flagged, `DATE_CARD_FEATURE_ENABLED`).
  /// `venuePhotoUrl` is an absolute, operator-owned URL from a curated venue
  /// (clean licensing). `venuePhotoName` is a Google Places photo *resource
  /// name* (`places/X/photos/Y`); the displayable media URL is rebuilt at card
  /// render time with the server-side key (`buildPlacesPhotoUrl`) so Google's
  /// raw bytes are never persisted (Places ToS). Both null until `scheduled`.
  venuePhotoUrl      String? @map("venue_photo_url")
  venuePhotoName     String? @map("venue_photo_name")
  /// Telegram photo `file_id` of the rendered date-card PNG, captured per side
  /// the first time the `scheduled` confirmation card is sent
  /// (`DATE_CARD_FEATURE_ENABLED`). Lets the "My date" menu hub re-open the card
  /// instantly instead of re-rendering it (satori/resvg is a multi-second beat).
  /// Null until the card is actually sent (feature off, render/send failed, or
  /// the plain-text fallback was used). Cleared implicitly by never being read
  /// once the match leaves `scheduled`.
  dateCardFileIdA    String? @map("date_card_file_id_a")
  dateCardFileIdB    String? @map("date_card_file_id_b")
  /// Idempotency marker: when the concierge prompt was dispatched to both users.
  venuePromptAskedAt DateTime? @map("venue_prompt_asked_at")

  /// Phase 4: Date lifecycle
  icebreakersSentAt    DateTime? @map("icebreakers_sent_at")
  /// Phase 4: Safety note sent to the female user 1.5h before `agreedTime`.
  /// Idempotency marker — null = not yet sent, timestamp = sent.
  safetyNoteSentAt     DateTime? @map("safety_note_sent_at")
  emergencyCancelledBy String?   @map("emergency_cancelled_by") @db.Uuid
  emergencyReason      String?   @map("emergency_reason")
  feedbackByA          String?   @map("feedback_by_a")
  feedbackByB          String?   @map("feedback_by_b")
  /// Idempotency marker for the post-date feedback DM. The prompt is sent
  /// once per match 24h after `agreedTime`; this column gates the cron tick
  /// so the same pair can't be re-prompted every 2 minutes when one or
  /// both users haven't replied yet. Pre-C-1 the cron used the status flip
  /// to `completed` + the null check on `feedbackBy{A,B}` as a dedup, which
  /// re-fired forever for unanswered prompts.
  feedbackPromptedAt   DateTime? @map("feedback_prompted_at")

  /// Timestamp when the AI pitch was dispatched to both users via the queue.
  /// Used by the 24h TTL cron to expire unanswered proposals.
  dispatchedAt DateTime? @map("dispatched_at")

  /// Telegram `message_id` of the dispatched pitch DM, captured per side.
  /// Used by the proposal-countdown worker to live-edit the "⏳ Xч left"
  /// plate, and by the expiry tick to overwrite the pitch with a final
  /// "срок истёк" notice. NULL when the user has no Telegram presence
  /// (mobile-first account, `telegramId <= 0`) or when send failed.
  pitchMessageIdA Int? @map("pitch_message_id_a")
  pitchMessageIdB Int? @map("pitch_message_id_b")

  /// Telegram `message_id` of the current Calendar Mini App card per side.
  /// Scheduling status updates replace this card instead of stacking another
  /// "Open Calendar" message in the chat. Cleared when a time is locked.
  calendarMessageIdA Int? @map("calendar_message_id_a")
  calendarMessageIdB Int? @map("calendar_message_id_b")

  /// Legacy nudge columns from the pre-C-6 era when proposal-phase and
  /// scheduling-phase nudges shared the same two slots. Kept nullable so old
  /// rows still parse — new code reads/writes the four phase-specific columns
  /// below. Safe to drop after a few release cycles.
  nudge1SentAt DateTime? @map("nudge1_sent_at")
  nudge2SentAt DateTime? @map("nudge2_sent_at")
  /// Proposal-phase nudges (status = "proposed", awaiting accept/decline).
  /// First reminder ≥3h after dispatchedAt, second ≥10h after.
  proposalNudge1SentAt DateTime? @map("proposal_nudge1_sent_at")
  proposalNudge2SentAt DateTime? @map("proposal_nudge2_sent_at")
  /// Scheduling-phase nudges (status = "negotiating", both accepted but no
  /// agreed slot yet). First reminder ≥6h since last update, second ≥12h.
  /// Split from the proposal nudges in C-6 so a row that already received a
  /// proposal nudge doesn't dead-letter the scheduling phase's nudge cadence.
  schedNudge1SentAt DateTime? @map("sched_nudge1_sent_at")
  schedNudge2SentAt DateTime? @map("sched_nudge2_sent_at")

  /// Phase 4 mobile: personalised ice-breakers persisted per side so the
  /// Expo app can display the same topics that Telegram users receive via DM.
  /// Populated by `runDateLifecycleTick` in the same step that marks
  /// `icebreakersSentAt`.
  iceBreakersA String[] @default([]) @map("ice_breakers_a")
  iceBreakersB String[] @default([]) @map("ice_breakers_b")

  /// Phase 4 mobile: per-side acknowledgement of the pre-date safety brief.
  /// Flipped by POST /v1/matches/:id/safety-ack. Independent from
  /// `safetyNoteSentAt` which only tracks the Telegram DM dispatch.
  safetyAckA Boolean @default(false) @map("safety_ack_a")
  safetyAckB Boolean @default(false) @map("safety_ack_b")

  /// Phase 4 "Wingman": single asymmetric insider tip per side. Generated
  /// when the match flips to `scheduled` (venue locked) and revealed to
  /// each side only within T-1.5h of `agreedTime` via the serializer gate.
  /// `wingmanSentAt` is the T-1.5h push idempotency marker.
  wingmanHintA       String?   @map("wingman_hint_a")
  wingmanHintB       String?   @map("wingman_hint_b")
  wingmanSentAt      DateTime? @map("wingman_sent_at")

  /// Date Ticket monetization gate. Sits between mutual accept and the
  /// Calendar Mini App when `TICKET_FEATURE_ENABLED=true`; entirely inert
  /// when the flag is off (no offer is ever sent, columns keep defaults).
  /// Payment is MOCKED in v1 — see `services/ticket-payment.ts`; the
  /// `mock`/`stripe` switch is the single production toggle.
  ///
  /// `ticketStatus` lifecycle (string, validated in app code — not a Prisma
  /// enum, so adding states later needs no migration):
  ///   pending   — offer sent, neither side paid
  ///   partial   — exactly one side paid; `ticketExpiresAt` is the second
  ///               side's deadline
  ///   completed — both sides paid; scheduling unlocked
  ///   refunded  — `partial` lapsed; the paying side was refunded (mock) and
  ///               scheduling was opened for free (an accepted match is never
  ///               killed by a payment stall)
  ///   expired   — offer lapsed with nobody paid; scheduling opened for free
  ticketPriceCents  Int       @default(699) @map("ticket_price_cents")
  ticketPaidA       DateTime? @map("ticket_paid_a")
  ticketPaidB       DateTime? @map("ticket_paid_b")
  /// Set when a male user pays the $13.98 "for both of us" option — records
  /// which side settled the partner's ticket so the partner's Mini App shows
  /// the "[Name] already paid your ticket ❤️" screen.
  paidForPartnerByA Boolean   @default(false) @map("paid_for_partner_by_a")
  paidForPartnerByB Boolean   @default(false) @map("paid_for_partner_by_b")
  /// Read-receipt for the goodwill "he covered her ticket" gesture (§3.5b).
  /// `partnerPaidSeenAt` is stamped the first time the covered partner actually
  /// learns of it — either by opening the ticket-card reveal or by receiving the
  /// completion nudge — and gates the one-time "she saw it ❤️" DM back to the
  /// payer so it fires once. `partnerPaidNudgedAt` marks that the fallback nudge
  /// DM was sent to the covered partner (she never opened the card before the
  /// gate completed), so the nudge can't double-fire.
  partnerPaidSeenAt   DateTime? @map("partner_paid_seen_at")
  partnerPaidNudgedAt DateTime? @map("partner_paid_nudged_at")
  ticketStatus      String    @default("pending") @map("ticket_status")
  /// Deadline for the second side to pay once the first has (the `partial`
  /// window). Drives the Mini App countdown and the hourly ticket-expiry
  /// cron's refund sweep. Null outside the `partial` state.
  ticketExpiresAt   DateTime? @map("ticket_expires_at")

  /// --- Pre-date coordination (feature-flagged, PRODUCT_SPEC §Phase 4) ---
  /// String sub-state machine layered on top of a `scheduled` match — like
  /// `ticketStatus`, deliberately not a Prisma enum so the scheduling/venue
  /// lifecycle code is untouched. Inert when `COORDINATION_FEATURE_ENABLED`
  /// is off. The female participant (or, in same-sex pairs, whoever taps
  /// first) is offered three ways to find each other at the spot at T-60m.
  coordOfferSentAt    DateTime? @map("coord_offer_sent_at")
  /// User who actually picked a method (the offer's first tapper).
  coordInitiatorId    String?   @map("coord_initiator_id") @db.Uuid
  /// share_self (A) | request_partner (B) | proxy (C). Null = not chosen yet.
  coordMethod         String?   @map("coord_method")
  coordChosenAt       DateTime? @map("coord_chosen_at")
  /// Variant B ONLY: null = awaiting partner, true = approved (contact
  /// revealed), false = declined. Variant C opens unconditionally (no consent)
  /// so an offline partner can never strand the initiator at T-30m.
  coordPartnerConsent Boolean?  @map("coord_partner_consent")
  /// Terminal stamp: contact revealed (A/B) or proxy method locked in (C).
  coordResolvedAt     DateTime? @map("coord_resolved_at")
  /// Variant C anonymous proxy window. Opened at T-30m by the coordination
  /// cron, closed at agreed_time + PROXY_CLOSE_AFTER_HOURS.
  proxyOpenedAt       DateTime? @map("proxy_opened_at")
  proxyClosesAt       DateTime? @map("proxy_closes_at")
  proxyClosedAt       DateTime? @map("proxy_closed_at")

  /// --- Venue change v2 (feature-flagged, paid multiplayer board) ---
  /// String sub-state layered on a `scheduled` match — like `ticketStatus`
  /// and `coordMethod`, deliberately NOT a MatchStatus enum value so the
  /// scheduling/venue/lifecycle code that switches on `status` is untouched.
  /// Inert when VENUE_CHANGE_FEATURE_ENABLED is off. v2 lifecycle
  /// (PRODUCT_SPEC §3.7b — the v1 propose/veto values are retired; the
  /// feature never launched, so no in-flight v1 rows exist):
  ///   null      — no session (nobody liked anything yet)
  ///   "liking"  — board session open; likes exist, no agreement yet
  ///   "agreed"  — a venue is agreed (board overlap or express mint),
  ///               awaiting the VENUE_CHANGE_STARS payment; the venueChange*
  ///               fields below hold the agreed venue
  ///   "settled" — paid; venueChange* copied onto the canonical venue* fields
  ///   "lapsed"  — payment deadline passed unpaid → original venue stands
  ///               (the match is NEVER cancelled by a venue change)
  venueChangeStatus     String?   @map("venue_change_status")
  /// v2: the session INITIATOR — whoever placed the session's first like (or
  /// minted the express invoice). Drives the payer matrix: hetero → the male
  /// pays regardless; same-sex → the initiator pays.
  venueChangeProposerId String?   @map("venue_change_proposer_id") @db.Uuid
  /// v2: session-open stamp (first like / express mint). CAS guard for the
  /// initiator claim.
  venueChangeProposedAt DateTime? @map("venue_change_proposed_at")
  /// Payment deadline for an `agreed` venue = min(agreedAt +
  /// VENUE_CHANGE_TTL_HOURS, agreedTime - DATE_ALERT_HOURS). Drives the
  /// lifecycle lapse sweep.
  venueChangeExpiresAt  DateTime? @map("venue_change_expires_at")
  venueChangeResolvedAt DateTime? @map("venue_change_resolved_at")
  /// Agreed replacement venue (server-resolved catalog snapshot — never the
  /// client's own strings).
  venueChangeName       String?   @map("venue_change_name")
  venueChangeAddress    String?   @map("venue_change_address")
  venueChangeLat        Float?    @map("venue_change_lat")
  venueChangeLng        Float?    @map("venue_change_lng")
  venueChangeMapsUri    String?   @map("venue_change_maps_uri")
  venueChangePlaceId    String?   @map("venue_change_place_id")
  /// Legacy v1 column (the mandatory-comment relay) — retained, never written
  /// by v2 (the board has no free text at all).
  venueChangeComment    String?   @map("venue_change_comment")
  /// v2 board likes, one Json[] per side. Each entry is a server-resolved
  /// venue snapshot: { key, placeId, name, address, lat, lng, mapsUri,
  /// category, photoUrl, photoRef }. `key` = placeId ?? "name|address".
  venueLikesA           Json[]    @map("venue_likes_a")
  venueLikesB           Json[]    @map("venue_likes_b")
  /// Agreed-venue photo refs (curated absolute URL / Places photo resource
  /// name), copied onto venuePhotoUrl/venuePhotoName at settle so the updated
  /// date card renders the NEW venue's photo.
  venueChangePhotoUrl   String?   @map("venue_change_photo_url")
  venueChangePhotoName  String?   @map("venue_change_photo_name")
  /// Who actually paid the Stars and when (settle stamp).
  venueChangePaidById   String?   @map("venue_change_paid_by_id") @db.Uuid
  venueChangePaidAt     DateTime? @map("venue_change_paid_at")
  /// The male's single, final "not this time" on paying (his finalizer fork
  /// or the wish card). Non-null permanently hides her "offer him to pay"
  /// option for this session.
  venueChangePayDeclinedAt DateTime? @map("venue_change_pay_declined_at")
  /// Wish-card guard: set once when she offers him to pay (no duplicate cards).
  venueChangeOfferPaySentAt DateTime? @map("venue_change_offer_pay_sent_at")
  /// Board-invite DM per recipient side: when it was last (re)sent, and the id
  /// of the message currently living in their chat. There is only ever ONE such
  /// message per side — a fresh submission deletes the previous one and posts a
  /// new one, so the invite is always the latest message rather than a pile of
  /// near-identical pings while the pair is still making up their minds.
  venueChangePingSentToAAt DateTime? @map("venue_change_ping_sent_to_a_at")
  venueChangePingSentToBAt DateTime? @map("venue_change_ping_sent_to_b_at")
  venueChangePingMsgIdA    Int?      @map("venue_change_ping_msg_id_a")
  venueChangePingMsgIdB    Int?      @map("venue_change_ping_msg_id_b")
  /// Non-null marks the current `agreed` state as an EXPRESS mint (her
  /// unilateral silent swap): hidden from the partner until settled, and a
  /// lapse stays silent for the partner (they never knew).
  venueChangeExpressAt  DateTime? @map("venue_change_express_at")

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  userA User @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)

  events MatchEvent[]
  reports Report[]
  scoreLog MatchScoreLog?
  proxyMessages ProxyMessage[]

  @@index([status, createdAt])
  @@index([userAId, userBId])
  /// Drives the ticket-expiry cron's sweep for `partial`/`pending` rows
  /// whose `ticketExpiresAt` has lapsed.
  @@index([ticketStatus, ticketExpiresAt])
  /// Drives the coordination cron's T-60m offer sweep.
  @@index([status, coordOfferSentAt])
  /// Drives the coordination cron's proxy open/close sweeps.
  @@index([coordMethod, proxyClosedAt])
  /// Drives the venue-change TTL/cutoff expiry sweep on the lifecycle tick.
  @@index([venueChangeStatus, venueChangeExpiresAt])
  @@map("matches")
}

/// Append-only audit log of every message relayed through a Variant C
/// anonymous proxy chat. Backs the moderation trail that justifies the
/// time-boxed carve-out to the "NO IN-APP CHAT" product invariant — relayed
/// content is fully logged and reportable. Cascades on Match deletion (GDPR).
model ProxyMessage {
  id        String   @id @default(uuid()) @db.Uuid
  matchId   String   @map("match_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@map("proxy_messages")
}

/// Score breakdown frozen at match-creation time. One row per Match.
/// Powers `/admin/analytics/algorithm`: lets us correlate each component
/// (V_explicit, V_research, V_league, V_penalty) against the eventual
/// accept/decline outcome — needed for A/B testing scoring weights.
/// Decoupled from `Match` so the heavy analytics scans don't touch the
/// hot match table.
model MatchScoreLog {
  id                String   @id @default(uuid()) @db.Uuid
  matchId           String   @unique @map("match_id") @db.Uuid
  /// Embedding cosine similarity in [0..1] (1 = identical).
  scoreExplicit     Float    @map("score_explicit")
  /// Sociological heuristic score in [0..1].
  scoreResearch     Float    @map("score_research")
  /// Elo-distance multiplier in [0..1] (1 = same league).
  scoreLeague       Float    @map("score_league")
  /// Negative-constraint penalty in [0..1] (higher = worse).
  scorePenalty      Float    @map("score_penalty")
  /// Stated age-range preference multiplier in [floor..1] (1 = candidate in the
  /// seeker's preferred partner age band, or no band set). Multiplies the
  /// positive bracket alongside `scoreLeague`. Defaults to 1 so historical rows
  /// logged before this factor existed read as neutral.
  scoreAgePref      Float    @default(1) @map("score_age_pref")
  /// Final composite (after weights + starvation bonus).
  scoreTotal        Float    @map("score_total")
  /// Pairwise embedding L2 distance, kept for debugging / re-ranking.
  embeddingDistance Float?   @map("embedding_distance")
  /// Capped priority bonus from the starvation tier (max of two sides).
  starvationBonus   Float    @default(0) @map("starvation_bonus")
  createdAt         DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([scoreTotal])
  @@map("match_score_logs")
}

model MatchEvent {
  id         String               @id @default(uuid()) @db.Uuid
  matchId    String               @map("match_id") @db.Uuid
  actorId    String               @map("actor_id") @db.Uuid
  targetId   String               @map("target_id") @db.Uuid
  actionType MatchEventActionType @map("action_type")
  metadata   Json?
  createdAt  DateTime             @default(now()) @map("created_at")

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  actor  User  @relation("MatchEventActor", fields: [actorId], references: [id], onDelete: Cascade)
  target User  @relation("MatchEventTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@index([actorId, createdAt])
  @@index([targetId, createdAt])
  @@index([actionType, createdAt])
  @@map("match_events")
}

/// Post-match report filed by one participant against the other.
/// LLM-triaged into Tier 1 (preference), Tier 2 (ethical), or Tier 3 (safety).
/// Tier 3 rows stay `adminReviewed=false` until a human clears them.
model Report {
  id            String   @id @default(uuid()) @db.Uuid
  reporterId    String   @map("reporter_id") @db.Uuid
  reportedId    String   @map("reported_id") @db.Uuid
  matchId       String   @map("match_id") @db.Uuid
  rawText       String   @map("raw_text")
  tier          Int
  reasonSummary String?  @map("reason_summary")
  adminReviewed Boolean  @default(false) @map("admin_reviewed")
  createdAt     DateTime @default(now()) @map("created_at")

  reporter User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User  @relation("ReportReported", fields: [reportedId], references: [id], onDelete: Cascade)
  match    Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([reporterId, matchId])
  @@index([reportedId, tier, createdAt])
  @@index([tier, adminReviewed, createdAt])
  @@map("reports")
}

/// Append-only upload-time validation rejection log. Contains only coarse
/// reason codes and media type, never raw media, provider payloads, face crops,
/// hashes, embeddings, or user-facing file identifiers.
model MediaValidationRejection {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  mediaType       String   @map("media_type")
  rejectionReason String   @map("rejection_reason")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([mediaType, rejectionReason, createdAt])
  @@map("media_validation_rejections")
}

model BotSession {
  key       String   @id
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bot_sessions")
}

/// Email-OTP challenges for the public mobile API (`POST /v1/auth/otp/*`).
/// Keyed by email (not userId) — user rows may not exist yet at request time.
/// `code` is stored as a bcrypt hash; raw code is only delivered via email.
model EmailOtp {
  id         String    @id @default(uuid()) @db.Uuid
  email      String
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  attempts   Int       @default(0)
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([email, createdAt])
  @@map("email_otps")
}

/// Native-app phone-code challenges (general track on iOS/Android, where the
/// Telegram one-tap `message.contact` rail does not exist). Twin of
/// `email_otps`, keyed by E.164 phone because the funnel starts before a User
/// row exists. `provider` records the delivery rail: "telegram_gateway"
/// stores our own bcrypt code hash (we generate the code and verify locally);
/// "twilio_verify" delegates code generation/checking to Twilio Verify
/// (`codeHash` null, `providerRequestId` = the Verification SID).
model PhoneOtp {
  id                String    @id @default(uuid()) @db.Uuid
  phone             String
  provider          String
  codeHash          String?   @map("code_hash")
  providerRequestId String?   @map("provider_request_id")
  expiresAt         DateTime  @map("expires_at")
  attempts          Int       @default(0)
  consumedAt        DateTime? @map("consumed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([phone, createdAt])
  @@map("phone_otps")
}

/// Browser pre-registration handoff into Telegram.
/// The raw token is returned to the browser once and placed in the Telegram
/// deep link (`/start web_<token>`). Only its SHA-256 hash is stored here, so
/// logs and DB snapshots do not expose a usable account-linking secret.
model WebRegistrationLink {
  id        String @id @default(uuid()) @db.Uuid
  tokenHash String @unique @map("token_hash")
  /// Registration v2 track picked on the website. `student` — the university
  /// email below was OTP-verified on the site. `general` — the user chose the
  /// phone rail, which the website deliberately does NOT verify: a number is
  /// only ever trusted from Telegram's own `message.contact` one-tap, so the
  /// handoff carries the *choice* and the bot's Mini App runs the actual gate.
  /// Null on links minted before the fork existed (all of them were student).
  registrationTrack String? @map("registration_track")
  /// Verified university email — student track only, hence nullable. A general
  /// track link has no email at all.
  email            String?
  universityDomain String? @map("university_domain")
  language         Language
  purpose          WebRegistrationPurpose @default(join)
  termsAccepted    Boolean  @map("terms_accepted")
  termsAcceptedAt  DateTime @map("terms_accepted_at")
  researchOptIn    Boolean  @default(false) @map("research_opt_in")
  /// Dating city picked on the website (student track only — the general track
  /// picks its city in the Mini App, right after the phone gate). Mirrors the
  /// `Profile` columns so the handoff can satisfy the city gate and the user
  /// never re-answers it in Telegram.
  homeCity           String?   @map("home_city")
  homeCountryCode    String?   @map("home_country_code")
  homeCityKey        String?   @map("home_city_key")
  homePlaceId        String?   @map("home_place_id")
  latitude           Float?
  longitude          Float?
  expiresAt          DateTime  @map("expires_at")
  consumedAt         DateTime? @map("consumed_at")
  consumedTelegramId BigInt?   @map("consumed_telegram_id")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@index([email, createdAt])
  @@index([expiresAt, consumedAt])
  @@map("web_registration_links")
}

/// Active mobile refresh tokens. Access JWTs are stateless; refresh tokens are
/// persisted here (hashed) so revocation / rotation is server-controlled.
model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("user_sessions")
}

model SystemKnowledge {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  title     String
  content   String   @db.Text
  category  String   @default("general")
  priority  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_knowledge")
}

enum MessageRole {
  user
  assistant
  system
}

/// Aether Concierge multimodal chat history. Distinct from `User.messageHistory`
/// (Json[] blob used by the legacy onboarding/menu agents) — this row-per-message
/// table powers the mobile-side chat UI with image attachments.
///
/// `imageUrl` stores the *opaque* Supabase Storage path (e.g.
/// `{userId}/{ts}.jpg`), never a public URL. Renderers mint short-lived signed
/// URLs at read time via `createChatImageSignedUrl`.
model Message {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  role      MessageRole
  content   String      @db.Text
  imageUrl  String?     @map("image_url")
  createdAt DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("messages")
}

/// Audit row for the empathetic "no match this week" DM that fires ~15 min
/// after the Thursday batch for every `active` user the matcher couldn't pair.
/// `tier` is the consecutive-famine count (1 = first week without a match,
/// 2 = second, 3+ = third or more) — drives the escalating warmth of the
/// template selected from `i18n.noMatchThisWeek*`. `dropDate` is truncated
/// to the UTC day of the cron firing so `@@unique([userId, dropDate])`
/// doubles as an idempotency guard against accidental re-fires within the
/// same drop. Read by `/admin/analytics/no-match-notices` for week-over-week
/// trend tracking — a rising count signals the matchmaker / user base needs
/// attention before users churn.
model NoMatchNotice {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tier      Int
  sentAt    DateTime @default(now()) @map("sent_at")
  dropDate  DateTime @map("drop_date")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dropDate])
  @@index([dropDate])
  @@index([sentAt])
  @@map("no_match_notices")
}

/// Hand-curated first-date venues, scoped per university domain. This is the
/// PRIMARY source for the concierge venue picker (PRODUCT_SPEC §3.7): Google
/// Places is only consulted as a fallback when no curated venue is in range.
/// The product's hyper-local rule (both matched users share `universityDomain`)
/// keeps the geography — and therefore the curation effort — small.
///
/// Standalone model (no user relation): scoped by the `universityDomain` string
/// the same way the matching pipeline filters candidates. Populated by
/// `scripts/seed-venues.mjs` (Places-backed pull → manual review → import).
model CuratedVenue {
  id               String    @id @default(uuid()) @db.Uuid
  universityDomain String    @map("university_domain")
  name             String
  address          String
  lat              Float
  lng              Float
  /// Google Maps deep-link (always present for seeded venues; nullable for
  /// hand-entered rows). Surfaced in the scheduled-date DM.
  googleMapsUri    String?   @map("google_maps_uri")
  /// Google Places resource id. Lets the re-validation cron re-fetch the exact
  /// place (Place Details) rather than re-searching by name. Null for
  /// hand-entered rows (which the cron skips).
  placeId          String?   @map("place_id")
  /// The venue's UTC offset in minutes (e.g. Kyiv = 180). Used with
  /// `openingHours` to evaluate open-at-slot in local wall-clock time.
  utcOffsetMinutes Int?      @map("utc_offset_minutes")
  /// Places `regularOpeningHours` (`periods[]`), captured at seed + refreshed by
  /// the re-validation cron. Null = unknown → treated as "open" (never filtered).
  openingHours     Json?     @map("opening_hours")
  /// One of VENUE_CATEGORY_WHITELIST (validated in app code, not a Prisma enum,
  /// so the shared whitelist stays the single source of truth).
  category         String
  /// 1 = best first-date spot, 3 = acceptable. Lower wins ties in ranking.
  priority         Int       @default(2)
  vibeTags         String[]  @default([]) @map("vibe_tags")
  /// Operator-supplied venue photo URL (Supabase Storage or any hosted image),
  /// filled by hand for venues we curate. Surfaced in the venue-change catalog
  /// Mini App card. Null for seeded-but-not-yet-photographed rows; Places-
  /// fallback catalog entries have no photo (the Mini App shows a category
  /// placeholder). Not used by the auto-assign concierge picker.
  photoUrl         String?   @map("photo_url")
  active           Boolean   @default(true)
  /// Set when the row was last confirmed live against Places (by the seeder
  /// import, or the re-validation cron). Oldest-first is the cron's scan order.
  lastVerifiedAt   DateTime? @map("last_verified_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([universityDomain, category, active])
  @@map("curated_venues")
}

/// Snapshot of a weekly founder matches report (gated by `FOUNDER_NOTIFY_ENABLED`).
/// Built after the Thursday batch (`notifyFounderWeeklyMatches`), stored so the
/// tokenized report page (`GET /v1/founder/report/:token`) renders a stable view
/// regardless of later profile edits. Contains PII (names, cities, photo refs,
/// attractiveness scores) but never `psychologicalSummary`/AI-memory dumps. The
/// `token` is a cryptographically-random unguessable string = the page's only
/// authorization (no login), so it must never be logged.
model FounderReport {
  id        String   @id @default(uuid()) @db.Uuid
  /// Crypto-random URL token = the report page's sole authorization.
  token     String   @unique
  /// UTC day of the batch this report covers (dedup + display).
  weekOf    DateTime @map("week_of")
  /// Assembled `WeeklyMatchesReport` snapshot (pairs + user cards + photo refs).
  dataJson  Json     @map("data_json")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("founder_reports")
}
