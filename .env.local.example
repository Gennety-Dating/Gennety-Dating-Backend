# ─────────────────────────────────────────────────────────────
# Local development environment.
#
# Copy to `.env.local` and fill in the blanks:
#   cp .env.local.example .env.local
#
# `.env.local` is gitignored and loaded BEFORE `.env` by the bot,
# so any value set here overrides the production `.env` without
# ever modifying it. Delete `.env.local` to fall back to prod.
# ─────────────────────────────────────────────────────────────

# --- Telegram ----------------------------------------------------------------
# Dev bot token from @BotFather. Must be a SEPARATE bot from the production
# one — otherwise long polling will race with the prod server for updates.
BOT_TOKEN=

# --- Database (local Postgres via docker-compose.dev.yml) --------------------
# Matches credentials in docker-compose.dev.yml. Port 5434 is offset from the
# test DB (5433) so both can run at the same time.
DATABASE_URL=postgresql://gennety:gennety@localhost:5434/gennety_dev

# --- OpenAI / Resend (reuse prod keys locally is fine) -----------------------
OPENAI_API_KEY=

# SMTP via Resend — leave empty to disable OTP email (won't block bot startup,
# but email verification step will fail until you set these).
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=onboarding@yourdomain.com

# --- Optional ----------------------------------------------------------------
# Mini App URL. For local Mini App development, expose Vite via cloudflared
# tunnel and paste the https URL here, then register it in BotFather.
# WEBAPP_URL=https://your-tunnel.trycloudflare.com

# Custom emoji IDs — leave empty to fall back to Unicode 👍/👎.
# CUSTOM_EMOJI_LIKE_ID=
# CUSTOM_EMOJI_DISLIKE_ID=
# CUSTOM_EMOJI_MENU_ID=

# Admin dashboard — set ADMIN_API_KEY to enable /admin HTTP server locally.
# ADMIN_API_KEY=
# ADMIN_PORT=3100
# ADMIN_DASHBOARD_ORIGIN=*

# --- Public /v1/* API (for the Expo mobile app) ------------------------------
# JWT_SECRET is required to enable the public server. Generate a 64+ char
# random string (e.g. `openssl rand -hex 48`). Leave empty to keep the public
# API disabled locally.
# JWT_SECRET=
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=30d
# PUBLIC_PORT=3101
# PUBLIC_CORS_ORIGIN=*

# Expo Push Service token — https://expo.dev/accounts/<you>/settings/access-tokens
# Leave empty to disable push notifications (mobile app still works, just no
# OS-level push).
# EXPO_ACCESS_TOKEN=

# Supabase Storage for live-selfie uploads.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SELFIE_BUCKET=selfies
