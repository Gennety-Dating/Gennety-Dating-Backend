# Local development environment.
#
# Copy to `.env.local` and fill values:
#   cp .env.local.example .env.local
#
# `.env.local` is loaded before `.env`, so local values win without modifying
# production-like config. Use a separate dev Telegram bot token.

# --- Telegram ----------------------------------------------------------------
BOT_TOKEN=
BOT_USERNAME=
WEBAPP_URL=https://example.invalid/calendar
# Optional override for the Feedback Mini App URL. Empty falls back to
# `${WEBAPP_URL}/feedback.html` — fine when running both bundles from a
# single tunnel pointing at `apps/webapp`.
WEBAPP_FEEDBACK_URL=

# Optional Telegram visuals.
CUSTOM_EMOJI_LIKE_ID=
CUSTOM_EMOJI_DISLIKE_ID=
CUSTOM_EMOJI_MENU_ID=
CUSTOM_EMOJI_ACCEPT_ID=
CUSTOM_EMOJI_DECLINE_ID=
CUSTOM_EMOJI_VERIFIED_ID=
MESSAGE_EFFECT_MATCH_ID=
MESSAGE_EFFECT_FEEDBACK_ID=

# --- Local DB ----------------------------------------------------------------
# Matches docker-compose.dev.yml (port 5434).
DATABASE_URL=postgresql://gennety:gennety@localhost:5434/gennety_dev

# --- AI / Email --------------------------------------------------------------
OPENAI_API_KEY=
ONBOARDING_FACT_COLLECTOR_ENABLED=true

# Resend HTTP API. For local onboarding without sending email, keep
# OTP_LOG_TO_CONSOLE=true. `pnpm dev:bot` sets NODE_ENV=development; direct
# production-like starts intentionally reject this debug flag.
RESEND_API_KEY=
SMTP_FROM=onboarding@yourdomain.com
OTP_LOG_TO_CONSOLE=true

# DEV ONLY: comma-separated Telegram IDs that skip corporate-email OTP by
# creating synthetic verified `dev+<id>@gennety.dev` accounts.
DEV_OTP_BYPASS_TELEGRAM_IDS=

# --- Public /v1/* API --------------------------------------------------------
# Leave JWT_SECRET empty to keep the public API disabled locally.
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PUBLIC_PORT=3101
# `*` is a local-dev convenience (your tunnel origin varies). In production set
# concrete browser origins instead — empty now denies cross-origin (audit L3).
PUBLIC_CORS_ORIGIN=*

# --- Admin API ---------------------------------------------------------------
# Leave ADMIN_API_KEY empty to keep the admin API disabled locally.
ADMIN_API_KEY=
ADMIN_PORT=3100
ADMIN_DASHBOARD_ORIGIN=*

# --- Supabase storage --------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SELFIE_BUCKET=selfies
SUPABASE_PHOTO_BUCKET=profile-photos
SUPABASE_CHAT_BUCKET=chat-attachments

# --- Push --------------------------------------------------------------------
EXPO_ACCESS_TOKEN=

# --- Persona / face match ----------------------------------------------------
ENABLE_PERSONA_VERIFICATION=false
PERSONA_TEMPLATE_ID=
PERSONA_ENVIRONMENT_ID=
PERSONA_API_KEY=
PERSONA_WEBHOOK_SECRET=
PERSONA_HOSTED_URL_BASE=https://withpersona.com/verify

FACE_MATCH_PROVIDER=disabled
FACE_MATCH_THRESHOLD_VERIFY=0.85
FACE_MATCH_THRESHOLD_REVIEW=0.75
FACE_MATCH_MIN_VERIFIED_PHOTOS=1
ELO_VISION_SEED_ENABLED=false
PROFILE_MEDIA_VALIDATION_ENABLED=false
PROFILE_MEDIA_VALIDATION_FAIL_OPEN=false
PROFILE_VIDEO_MAX_ANALYSIS_FRAMES=24
PROFILE_VIDEO_VALIDATION_TIMEOUT_MS=60000

AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Venue picker ------------------------------------------------------------
PLACES_API_KEY=

# --- Optional worker overrides ----------------------------------------------
CRON_TIMEZONE=Europe/Kyiv
# DATE_LIFECYCLE_TICK_MS=120000
# DISPATCH_DELAY_MS=2000
